<div class="container mt-4">
  <h1 class="mb-4">Canada Community</h1>

  <%# Upload section %>
  <div class="cu-panel mb-5">
    <h2 class="cu-panel__title">Upload a Photo</h2>
    <%= simple_form_for @photo, url: photos_path do |f| %>
      <%= f.input :image, as: :file, label: "Choose a photo" %>
      <%= f.input :description, placeholder: "Add a caption..." %>
      <%= f.submit "Upload", class: "btn btn-primary" %>
    <% end %>
  </div>

  <%# My Photos section — only the current user's photos, with icon action buttons %>
  <div class="cu-panel mb-5">
    <h2 class="cu-panel__title">My Photos</h2>
    <% if @my_photos.none? %>
      <p class="text-muted">You haven't uploaded any photos yet.</p>
    <% else %>
      <div class="photo-grid">
        <% @my_photos.each do |photo| %>
          <% if photo.image.attached? %>
            <div class="photo-card">
              <%= image_tag photo.image, class: "photo-card__img" %>
              <div class="photo-card__body">
                <p class="photo-card__desc"><%= photo.description %></p>
                <%# [HW] Icon buttons in one row: edit (pen), delete (trash), share/unshare (share-nodes) %>
                <%# [HW] button_to generates a <form> — .photo-actions sets those forms to inline-flex %>
                <div class="photo-actions">
                  <%= link_to edit_photo_path(photo), class: "photo-action-btn", title: "Edit caption" do %>
                    <i class="fa-solid fa-pen"></i>
                  <% end %>
                  <%= button_to photo_path(photo), method: :delete,
                      class: "photo-action-btn photo-action-btn--danger",
                      title: "Delete photo",
                      data: { turbo_confirm: "Are you sure?" } do %>
                    <i class="fa-solid fa-trash"></i>
                  <% end %>
                  <%# [HW] shared? → blue filled icon (active). Not shared? → grey outline icon %>
                  <%= button_to toggle_share_photo_path(photo), method: :patch,
                      class: "photo-action-btn #{ photo.shared ? 'photo-action-btn--active' : '' }",
                      title: photo.shared ? "Unshare from feed" : "Share to community feed" do %>
                    <i class="fa-solid fa-share-nodes"></i>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Community Feed — all photos explicitly shared by any user %>
  <div class="cu-panel">
    <h2 class="cu-panel__title">Community Feed</h2>
    <% if @feed_photos.none? %>
      <p class="text-muted">No photos shared yet — be the first!</p>
    <% else %>
      <div class="photo-grid">
        <% @feed_photos.each do |photo| %>
          <% if photo.image.attached? %>
            <div class="photo-card">
              <%= image_tag photo.image, class: "photo-card__img" %>
              <div class="photo-card__body">
                <p class="photo-card__desc"><%= photo.description %></p>
                <small class="text-muted">By <%= photo.user.name %></small>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
