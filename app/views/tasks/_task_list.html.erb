<%# [MG] Task table — each row is tappable if it has a description (accordion via Stimulus) %>
<table class="task-table">
  <tbody>
    <% tasks.each do |task| %>
      <tr class="task-table__row <%= 'task-table__row--expandable' if task.description.present? %>"
    <% if task.description.present? %>
      data-controller="task-accordion"
      data-action="click->task-accordion#toggle"
    <% end %>>
        <td class="task-table__name"><%= task.name %></td>
        <td class="task-table__status">
          <span class="<%= "task-table__badge #{task_badge_class(task.status)}" %>">
            <%= task.status %>
          </span>
        </td>
        <td class="task-table__action">
          <% if task.description.present? %>
            <i class="fa-solid fa-chevron-down task-table__chevron"></i>
          <% end %>
          <% unless task.obligatory %>
            <% if task.status == "open" %>
              <%= button_to "Done?", task_path(task), method: :patch, params: { task: { status: "done" } }, class: "task-table__btn" %>
            <% else %>
              <%= button_to "Re-open?", task_path(task), method: :patch, params: { task: { status: "open" } }, class: "task-table__btn" %>
            <% end %>
          <% end %>
        </td>
      </tr>
      <% if task.description.present? %>
        <tr class="task-table__description-row">
          <td colspan="3" class="task-table__description"><%= task.description %></td>
        </tr>
      <% end %>
    <% end %>
  </tbody>
</table>
